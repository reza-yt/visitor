# ====================================
# AUTO VISITOR - ENVIRONMENT CONFIG
# ====================================
# Copy this to .env and fill in your values

# Target URLs (comma-separated)
TARGET_URLS=https://example.com,https://example.com/article-1

# Proxy list (comma-separated)
# Supported formats:
#   socks5://user:pass@host:port
#   socks4://host:port
#   http://user:pass@host:port
#   https://user:pass@host:port
#   user:pass@host:port           (defaults to http)
#   host:port                     (defaults to http)
#   host:port:user:pass           (alternative format)
PROXIES=
# PROXIES=socks5://user:pass@proxy1.com:1080,socks4://proxy2.com:1080,http://user:pass@proxy3.com:8080

# Visit Settings
TOTAL_VISITS=50
CONCURRENT_VISITS=2
DELAY_MIN=5000
DELAY_MAX=15000

# Behavior
SCROLL_DURATION=30000
CLICK_INTERNAL_LINKS=true
MAX_INTERNAL_CLICKS=3
SIMULATE_READING=true

# Mobile
MOBILE_RATIO=0.6

# Browser
HEADLESS=true
BROWSER_TIMEOUT=60000
ENGINE=puppeteer

# Warm-up
WARMUP_ENABLED=true

# Traffic Pattern
TRAFFIC_PATTERN_ENABLED=true
TRAFFIC_TIMEZONE=Asia/Jakarta

# Scheduler (cron hours, comma-separated)
SCHEDULER_ENABLED=false
SCHEDULER_HOURS=8,10,12,14,16,18,20
SCHEDULER_INTERVAL_MINUTES=60

# Proxy Health Check
PROXY_HEALTH_CHECK=true
PROXY_MAX_LATENCY=5000

# DNS over HTTPS
DOH_ENABLED=true

# Bandwidth Throttling
THROTTLE_ENABLED=true

# Logging
LOG_FORMAT=json
LOG_VERBOSE=true

# Telegram Notification
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Notification
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# Webhook Events (comma-separated: complete,error,captcha,progress)
WEBHOOK_EVENTS=complete,error,captcha

# ====================================
# YOUTUBE WEEK PACKAGE (1-Week Plan)
# ====================================

# YouTube Video URLs (comma-separated)
YOUTUBE_VIDEOS=
# YOUTUBE_VIDEOS=https://www.youtube.com/watch?v=VIDEO1,https://www.youtube.com/watch?v=VIDEO2

# Concurrent browsers (depends on RAM)
CONCURRENT=30

# Total RAM available (GB) - used to auto-calculate max concurrent
RAM=16

# Target watch hours (4000 + safety margin)
TARGET_HOURS=4200

# Video quality (144p = paling hemat bandwidth)
QUALITY=144p

# Cookies directory (file akun YouTube)
COOKIES_DIR=./cookies

# Proxy file (1 proxy per line: socks5://user:pass@host:port)
PROXY_FILE=./proxies.txt

# Max hours per day (spread over 7 days)
DAILY_MAX_HOURS=700
